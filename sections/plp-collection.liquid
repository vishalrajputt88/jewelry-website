      "label": "Show trust badge strip",
      "default": true
    },
    {
      "type": "header",
      "content": "Filters & Sorting"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable sidebar filters",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sort dropdown",
      "default": true
    },
    {
      "type": "text",
      "id": "filter_label",
      "label": "Filter heading",
      "default": "Refine"
    },
    {
      "type": "header",
      "content": "Labels"
    },
    {
      "type": "text",
      "id": "cart_btn_label",
      "label": "Add to cart button text",
      "default": "Add to Bag"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "default": "✦"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "BIS Hallmarked Gold"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PLP – Jewelry Collection",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "✦",
            "text": "BIS Hallmarked Gold"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "◈",
            "text": "IGI Certified Diamonds"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "◇",
            "text": "30-Day Free Returns"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "⬡",
            "text": "Free Shipping on ₹2,999+"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "✧",
            "text": "Lifetime Polishing"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "⊕",
            "text": "Easy EMI Available"
          }
        }
      ]
    }
  ]
}
{% endschema %}
