{% assign sid = section.id | replace: '_', '' | downcase %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
.jw-feat-{{ sid }} {
  background: {{ section.settings.section_background }};
  padding: {{ section.settings.section_padding_top }}px {{ section.settings.section_padding_horizontal }}px {{ section.settings.section_padding_bottom }}px;
}
.jw-feat-inner-{{ sid }} {
  max-width: {{ section.settings.max_width }}px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: {{ section.settings.column_gap }}px; align-items: center;
}
.jw-feat-img-{{ sid }} {
  position: relative;
}
.jw-feat-img-{{ sid }} img {
  width: 100%; display: block; object-fit: cover;
  border: 1px solid #e8e0d5;
}
.jw-feat-img-deco-{{ sid }} {
  position: absolute; top: -14px; left: -14px;
  width: 80px; height: 80px; border: 1px solid #b89b6a; z-index: -1;
}
.jw-feat-img-deco2-{{ sid }} {
  position: absolute; bottom: -14px; right: -14px;
  width: 80px; height: 80px; border: 1px solid #b89b6a; z-index: -1;
}
.jw-feat-content-{{ sid }} {}
.jw-feat-eyebrow-{{ sid }} {
  font-family: 'Jost', sans-serif;
  font-size: 10px; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase;
  color: {{ section.settings.tagline_color }};
  display: flex; align-items: center; gap: 12px; margin-bottom: 14px;
}
.jw-feat-eyebrow-{{ sid }}::before { content: ''; display: block; width: 28px; height: 1px; background: {{ section.settings.tagline_color }}; }
.jw-feat-heading-{{ sid }} {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(28px, 3vw, {{ section.settings.heading_size }}px);
  font-weight: 300; color: {{ section.settings.heading_color }};
  line-height: 1.15; margin-bottom: 16px; font-style: italic;
}
.jw-feat-text-{{ sid }} {
  font-family: 'Jost', sans-serif;
  font-size: {{ section.settings.text_size }}px; font-weight: 300;
  color: {{ section.settings.text_color }}; line-height: 1.8;
  letter-spacing: 0.02em; margin-bottom: {{ section.settings.text_margin }}px;
}
.jw-feat-divider-{{ sid }} { width: 40px; height: 1px; background: #b89b6a; margin-bottom: 20px; }

.jw-feat-points-{{ sid }} { display: flex; flex-direction: column; gap: 14px; margin-bottom: 28px; }
.jw-feat-point-{{ sid }} { display: flex; gap: 14px; align-items: flex-start; }
.jw-feat-point-icon-{{ sid }} {
  width: 36px; height: 36px; flex-shrink: 0;
  background: #1a1a1a; display: flex; align-items: center; justify-content: center;
}
.jw-feat-point-icon-{{ sid }} svg { width: 16px; height: 16px; stroke: #d4b896; fill: none; stroke-width: 1.5; }
.jw-feat-point-title-{{ sid }} {
  font-family: 'Jost', sans-serif; font-size: 11px; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase; color: #b89b6a; margin-bottom: 3px;
}
.jw-feat-point-text-{{ sid }} {
  font-family: 'Jost', sans-serif; font-size: 13px; font-weight: 300; color: #4a4a4a; letter-spacing: 0.02em;
}

.jw-feat-btn-{{ sid }} {
  display: inline-flex; align-items: center; gap: 10px;
  padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px;
  background: {{ section.settings.button_background }}; color: {{ section.settings.button_text_color }};
  border: 1px solid {{ section.settings.button_border_color }};
  font-family: 'Jost', sans-serif; font-size: 11px; font-weight: 600;
  letter-spacing: 0.16em; text-transform: uppercase; text-decoration: none;
  transition: all 0.25s; margin-top: {{ section.settings.button_margin_top }}px;
}
.jw-feat-btn-{{ sid }}:hover { background: {{ section.settings.button_hover_background }}; color: {{ section.settings.button_hover_text_color }}; border-color: {{ section.settings.button_hover_border_color }}; }
.jw-feat-btn-{{ sid }} svg { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2; transition: transform 0.2s; }
.jw-feat-btn-{{ sid }}:hover svg { transform: translateX(3px); }

@media(max-width:768px) {
  .jw-feat-inner-{{ sid }} { grid-template-columns: 1fr; gap: {{ section.settings.mobile_gap }}px; }
  .jw-feat-{{ sid }} { padding: {{ section.settings.mobile_padding_top }}px {{ section.settings.mobile_padding_horizontal }}px {{ section.settings.mobile_padding_bottom }}px; }
  .jw-feat-heading-{{ sid }} { font-size: {{ section.settings.mobile_heading_size }}px !important; }
}
</style>

<section class="jw-feat-{{ sid }}" {{ section.shopify_attributes }}>
  <div class="jw-feat-inner-{{ sid }}">
    <div class="jw-feat-img-{{ sid }}">
      {% if section.settings.product_image != blank %}
        <img src="{{ section.settings.product_image | image_url: width: 900 }}" alt="{{ section.settings.heading }}">
      {% elsif section.settings.featured_product != blank %}
        {% assign fp = all_products[section.settings.featured_product] %}
        {% if fp.featured_image %}
          <img src="{{ fp.featured_image | image_url: width: 900 }}" alt="{{ fp.title }}">
        {% endif %}
      {% endif %}
      <div class="jw-feat-img-deco-{{ sid }}"></div>
      <div class="jw-feat-img-deco2-{{ sid }}"></div>
    </div>
    <div class="jw-feat-content-{{ sid }}">
      {% if section.settings.tagline != blank %}
        <div class="jw-feat-eyebrow-{{ sid }}">{{ section.settings.tagline }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="jw-feat-heading-{{ sid }}">{{ section.settings.heading }}</h2>
      {% endif %}
      <div class="jw-feat-divider-{{ sid }}"></div>
      {% if section.settings.subheading != blank %}
        <p class="jw-feat-text-{{ sid }}">{{ section.settings.subheading }}</p>
      {% endif %}
      <div class="jw-feat-points-{{ sid }}">
        {% if section.settings.vision_title != blank %}
          <div class="jw-feat-point-{{ sid }}">
            <div class="jw-feat-point-icon-{{ sid }}"><svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></div>
            <div>
              <div class="jw-feat-point-title-{{ sid }}">{{ section.settings.vision_title }}</div>
              <div class="jw-feat-point-text-{{ sid }}">{{ section.settings.vision_text }}</div>
            </div>
          </div>
        {% endif %}
        {% if section.settings.mission_title != blank %}
          <div class="jw-feat-point-{{ sid }}">
            <div class="jw-feat-point-icon-{{ sid }}"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
            <div>
              <div class="jw-feat-point-title-{{ sid }}">{{ section.settings.mission_title }}</div>
              <div class="jw-feat-point-text-{{ sid }}">{{ section.settings.mission_text }}</div>
            </div>
          </div>
        {% endif %}
      </div>
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link | default: '#' }}" class="jw-feat-btn-{{ sid }}">
          {{ section.settings.button_text }}
          <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width",
      "min": 900,
      "max": 1600,
      "step": 50,
      "default": 1350
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column Gap",
      "min": 20,
      "max": 120,
      "step": 10,
      "default": 70
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "label": "Mobile Gap",
      "min": 20,
      "max": 60,
      "step": 4,
      "default": 36
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Background",
      "default": "#faf8f5"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding Top",
      "min": 20,
      "max": 120,
      "step": 10,
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding Bottom",
      "min": 20,
      "max": 120,
      "step": 10,
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "label": "Horizontal Padding",
      "min": 10,
      "max": 80,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 20,
      "max": 80,
      "step": 5,
      "default": 50
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 20,
      "max": 80,
      "step": 5,
      "default": 50
    },
    {
      "type": "range",
      "id": "mobile_padding_horizontal",
      "label": "Mobile Horizontal Padding",
      "min": 10,
      "max": 40,
      "step": 2,
      "default": 20
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Image"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Or select Product"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Eyebrow Text",
      "default": "Our Heritage"
    },
    {
      "type": "color",
      "id": "tagline_color",
      "label": "Eyebrow Color",
      "default": "#b89b6a"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafting Timeless Beauty Since 2008"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size (desktop)",
      "min": 24,
      "max": 64,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "mobile_heading_size",
      "label": "Heading Size (mobile)",
      "min": 20,
      "max": 48,
      "step": 2,
      "default": 30
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#4a4a4a"
    },
    {
      "type": "range",
      "id": "text_size",
