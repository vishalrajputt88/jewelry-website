      "id": "text_margin",
      "label": "Text Margin Bottom",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 20
    },
    {
      "type": "text",
      "id": "vision_title",
      "label": "Point 1 Title",
      "default": "Our Vision"
    },
    {
      "type": "textarea",
      "id": "vision_text",
      "label": "Point 1 Text"
    },
    {
      "type": "text",
      "id": "mission_title",
      "label": "Point 2 Title",
      "default": "Our Promise"
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Point 2 Text"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Explore Our Collections"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button BG",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text",
      "default": "#d4b896"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button Border",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button Hover BG",
      "default": "#b89b6a"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button Hover Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Button Hover Border",
      "default": "#b89b6a"
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Button Padding V",
      "min": 8,
      "max": 24,
      "step": 2,
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Button Padding H",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "button_margin_top",
      "label": "Button Margin Top",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}
