{% assign sid = section.id | replace: '_', '' | downcase %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
.jw-reviews-{{ sid }} {
  background: {{ section.settings.background_color }};
  padding: 80px 0;
}
.jw-rev-inner-{{ sid }} { max-width: 1440px; margin: 0 auto; padding: 0 28px; }
.jw-rev-header-{{ sid }} { text-align: center; margin-bottom: 48px; }
.jw-rev-eyebrow-{{ sid }} {
  font-family: 'Jost', sans-serif;
  font-size: 10px; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase;
  color: #b89b6a; margin-bottom: 10px;
  display: flex; align-items: center; justify-content: center; gap: 14px;
}
.jw-rev-eyebrow-{{ sid }}::before,.jw-rev-eyebrow-{{ sid }}::after { content: ''; display: block; width: 36px; height: 1px; background: #b89b6a; }
.jw-rev-title-{{ sid }} {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(28px, 3vw, 42px); font-weight: 300; font-style: italic;
  color: {{ section.settings.heading_color }}; line-height: 1.1;
}
.jw-rev-sub-{{ sid }} {
  font-family: 'Jost', sans-serif; font-size: 13px; font-weight: 300;
  color: {{ section.settings.subheading_color }}; letter-spacing: 0.03em;
  max-width: 560px; margin: 10px auto 0; line-height: 1.7;
}

/* Stars */
.jw-rev-stars-{{ sid }} { display: flex; gap: 3px; margin-bottom: 12px; }
.jw-rev-star-{{ sid }} { color: #b89b6a; font-size: 14px; }

/* Slider */
.jw-rev-outer-{{ sid }} { position: relative; overflow: hidden; }
.jw-rev-track-{{ sid }} {
  display: flex; gap: 24px;
  overflow-x: auto; scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch; scrollbar-width: none; cursor: grab;
}
.jw-rev-track-{{ sid }}:active { cursor: grabbing; }
.jw-rev-track-{{ sid }}::-webkit-scrollbar { display: none; }

/* Card */
.jw-rev-card-{{ sid }} {
  flex: 0 0 calc((100% - 48px) / 3);
  background: {{ section.settings.card_background }};
  border: 1px solid #e8e0d5;
  padding: 28px 26px 24px;
  scroll-snap-align: start;
  display: flex; flex-direction: column;
  position: relative;
}
.jw-rev-card-{{ sid }}::before {
  content: '\201C';
  font-family: 'Cormorant Garamond', serif;
  font-size: 72px; font-weight: 300; color: #e8e0d5;
  position: absolute; top: 10px; right: 20px;
  line-height: 1;
}
.jw-rev-text-{{ sid }} {
  font-family: 'Cormorant Garamond', serif;
  font-size: 17px; font-weight: 400; font-style: italic;
  color: #1a1a1a; line-height: 1.6; letter-spacing: 0.01em;
  margin-bottom: 20px; flex: 1;
}
.jw-rev-product-{{ sid }} {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 0; border-top: 1px solid #e8e0d5;
  border-bottom: 1px solid #e8e0d5; margin-bottom: 16px;
}
.jw-rev-prod-img-{{ sid }} { width: 44px; height: 54px; object-fit: cover; border: 1px solid #e8e0d5; flex-shrink: 0; background: #f5f0e8; }
.jw-rev-prod-info-{{ sid }} {}
.jw-rev-prod-name-{{ sid }} { font-family: 'Jost', sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.05em; color: #1a1a1a; margin-bottom: 2px; }
.jw-rev-prod-price-{{ sid }} { font-family: 'Cormorant Garamond', serif; font-size: 14px; color: #b89b6a; }
.jw-rev-customer-{{ sid }} { display: flex; align-items: center; gap: 10px; }
.jw-rev-avatar-{{ sid }} { width: 36px; height: 36px; border-radius: 50%; background: #1a1a1a; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-family: 'Jost', sans-serif; font-size: 13px; font-weight: 600; color: #d4b896; }
.jw-rev-cname-{{ sid }} { font-family: 'Jost', sans-serif; font-size: 12px; font-weight: 500; color: #1a1a1a; letter-spacing: 0.05em; }
.jw-rev-cloc-{{ sid }} { font-family: 'Jost', sans-serif; font-size: 10.5px; color: #8a8078; letter-spacing: 0.04em; }
.jw-rev-disc-{{ sid }} { position: absolute; top: 12px; left: 12px; background: #b89b6a; color: #fff; font-family: 'Jost', sans-serif; font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 7px; }

/* Nav */
.jw-rev-navs-{{ sid }} { display: flex; justify-content: center; gap: 10px; margin-top: 32px; }
.jw-rev-nav-{{ sid }} { width: 42px; height: 42px; border: 1px solid #e8e0d5; background: transparent; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; }
.jw-rev-nav-{{ sid }}:hover { background: #1a1a1a; border-color: #1a1a1a; }
.jw-rev-nav-{{ sid }} svg { width: 16px; height: 16px; stroke: #1a1a1a; fill: none; stroke-width: 2; }
.jw-rev-nav-{{ sid }}:hover svg { stroke: #d4b896; }

@media(max-width:768px) { .jw-rev-card-{{ sid }} { flex: 0 0 calc(100% - 28px); } }
</style>

<section class="jw-reviews-{{ sid }}" {{ section.shopify_attributes }}>
  <div class="jw-rev-inner-{{ sid }}">
    <div class="jw-rev-header-{{ sid }}">
      <div class="jw-rev-eyebrow-{{ sid }}">Testimonials</div>
      <h2 class="jw-rev-title-{{ sid }}">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="jw-rev-sub-{{ sid }}">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="jw-rev-outer-{{ sid }}">
      <div class="jw-rev-track-{{ sid }}" id="jw-rev-track-{{ sid }}">
        {% for block in section.blocks %}
          {% if block.type == 'review_item' %}
            {% assign prod = all_products[block.settings.product] %}
            <div class="jw-rev-card-{{ sid }}" {{ block.shopify_attributes }}>
              {% if block.settings.discount != blank %}
                <div class="jw-rev-disc-{{ sid }}">{{ block.settings.discount }} saved</div>
              {% endif %}
              <div class="jw-rev-stars-{{ sid }}">
                <span class="jw-rev-star-{{ sid }}">★</span><span class="jw-rev-star-{{ sid }}">★</span><span class="jw-rev-star-{{ sid }}">★</span><span class="jw-rev-star-{{ sid }}">★</span><span class="jw-rev-star-{{ sid }}">★</span>
              </div>
              <p class="jw-rev-text-{{ sid }}">"{{ block.settings.review_text }}"</p>
              {% if prod %}
                <div class="jw-rev-product-{{ sid }}">
                  {% if prod.featured_image %}
                    <img class="jw-rev-prod-img-{{ sid }}" src="{{ prod.featured_image | image_url: width: 120 }}" alt="{{ prod.title }}">
                  {% else %}
                    <div class="jw-rev-prod-img-{{ sid }}" style="display:flex;align-items:center;justify-content:center;font-size:18px;">💎</div>
                  {% endif %}
                  <div class="jw-rev-prod-info-{{ sid }}">
                    <div class="jw-rev-prod-name-{{ sid }}">{{ prod.title | truncate: 36 }}</div>
                    <div class="jw-rev-prod-price-{{ sid }}">{{ prod.price | money }}</div>
                  </div>
                </div>
              {% endif %}
              <div class="jw-rev-customer-{{ sid }}">
                <div class="jw-rev-avatar-{{ sid }}">{{ block.settings.customer_name | slice: 0, 1 | upcase }}</div>
                <div>
                  <div class="jw-rev-cname-{{ sid }}">{{ block.settings.customer_name }}</div>
                  {% if block.settings.customer_location != blank %}
                    <div class="jw-rev-cloc-{{ sid }}">{{ block.settings.customer_location }}</div>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="jw-rev-navs-{{ sid }}">
      <button class="jw-rev-nav-{{ sid }}" id="jw-rev-prev-{{ sid }}" aria-label="Previous">
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="jw-rev-nav-{{ sid }}" id="jw-rev-next-{{ sid }}" aria-label="Next">
        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
(function() {
  var track = document.getElementById('jw-rev-track-{{ sid }}');
  var prev  = document.getElementById('jw-rev-prev-{{ sid }}');
  var next  = document.getElementById('jw-rev-next-{{ sid }}');
  if (!track) return;
  function scroll(dir) {
    var card = track.querySelector('.jw-rev-card-{{ sid }}');
    if (!card) return;
    track.scrollBy({ left: dir * (card.offsetWidth + 24), behavior: 'smooth' });
  }
  if (prev) prev.addEventListener('click', function() { scroll(-1); });
  if (next) next.addEventListener('click', function() { scroll(1); });
  var isD = false; var sx, sl;
  track.addEventListener('mousedown', function(e) { isD = true; sx = e.pageX - track.offsetLeft; sl = track.scrollLeft; });
  track.addEventListener('mouseleave', function() { isD = false; });
  track.addEventListener('mouseup', function() { isD = false; });
  track.addEventListener('mousemove', function(e) { if (!isD) return; e.preventDefault(); track.scrollLeft = sl - (e.pageX - track.offsetLeft - sx); });
})();
</script>

{% schema %}
{
  "name": "Customer Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Thousands of happy customers trust us for their fine jewellery needs."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#6a6258"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#faf8f5"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card Background",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "review_item",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "discount",
          "label": "Discount label (e.g. 30%)"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer Name",
          "default": "Priya Sharma"
        },
        {
          "type": "text",
          "id": "customer_location",
          "label": "Location",
          "default": "Mumbai"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Customer Reviews",
      "blocks": [
        {
          "type": "review_item",
          "settings": {
            "review_text": "Absolutely stunning craftsmanship! The diamond necklace I ordered for my anniversary was breathtaking. Every detail was perfect and delivery was fast.",
            "customer_name": "Priya Sharma",
            "customer_location": "Mumbai"
          }
        },
        {
          "type": "review_item",
          "settings": {
            "review_text": "The gold bangles are exactly as shown — hallmarked and beautifully crafted. I've been wearing them every day and they still look flawless.",
            "customer_name": "Anjali Patel",
            "customer_location": "Ahmedabad"
          }
        },
        {
          "type": "review_item",
          "settings": {
            "review_text": "Ordered a bridal set and was blown away by the quality. The packaging was luxurious and the jewellery itself exceeded expectations.",
            "customer_name": "Neha Verma",
            "customer_location": "Delhi"
          }
        }
      ]
    }
  ]
}
{% endschema %}
