{% assign sid = section.id | replace: '_', '' | downcase %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
.jw-bs-{{ sid }} {
  padding: 72px 0;
  background: {{ section.settings.bg_color | default: '#faf8f5' }};
}
.jw-bs-inner-{{ sid }} { max-width: 1440px; margin: 0 auto; padding: 0 28px; }
.jw-bs-header-{{ sid }} {
  display: flex; align-items: flex-end; justify-content: space-between;
  margin-bottom: 36px; flex-wrap: wrap; gap: 12px;
}
.jw-bs-hgroup-{{ sid }} {}
.jw-bs-eyebrow-{{ sid }} {
  font-family: 'Jost', sans-serif;
  font-size: 10px; font-weight: 600; letter-spacing: 0.22em;
  text-transform: uppercase; color: #b89b6a;
  margin-bottom: 8px;
  display: flex; align-items: center; gap: 12px;
}
.jw-bs-eyebrow-{{ sid }}::before { content: ''; display: block; width: 28px; height: 1px; background: #b89b6a; }
.jw-bs-heading-{{ sid }} {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(28px, 3vw, 42px);
  font-weight: 300; font-style: italic;
  color: #1a1a1a; line-height: 1.1;
}
.jw-bs-viewall-{{ sid }} {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: 'Jost', sans-serif;
  font-size: 10.5px; font-weight: 600; letter-spacing: 0.14em;
  text-transform: uppercase; color: #1a1a1a; text-decoration: none;
  border-bottom: 1px solid #1a1a1a; padding-bottom: 2px;
  transition: color 0.2s, border-color 0.2s;
}
.jw-bs-viewall-{{ sid }}:hover { color: #b89b6a; border-color: #b89b6a; }
.jw-bs-viewall-{{ sid }} svg { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2; transition: transform 0.2s; }
.jw-bs-viewall-{{ sid }}:hover svg { transform: translateX(3px); }

/* Slider wrapper */
.jw-bs-outer-{{ sid }} { position: relative; }
.jw-bs-track-{{ sid }} {
  display: flex; gap: 20px;
  overflow-x: auto; scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none; padding-bottom: 4px; cursor: grab;
}
.jw-bs-track-{{ sid }}:active { cursor: grabbing; }
.jw-bs-track-{{ sid }}::-webkit-scrollbar { display: none; }

/* Card */
.jw-bs-card-{{ sid }} {
  flex: 0 0 calc((100% - {{ section.settings.products_per_row_desktop | minus: 1 | times: 20 }}px) / {{ section.settings.products_per_row_desktop }});
  background: #fff; border: 1px solid #e8e0d5;
  overflow: hidden; position: relative;
  display: flex; flex-direction: column;
  scroll-snap-align: start;
  transition: box-shadow 0.35s, border-color 0.35s;
}
.jw-bs-card-{{ sid }}:hover { box-shadow: 0 10px 40px rgba(26,20,10,0.12); border-color: #b89b6a; }

/* Badges */
.jw-bs-badge-{{ sid }} {
  position: absolute; top: 10px; left: 10px; z-index: 3;
  font-family: 'Jost', sans-serif;
  font-size: 9px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; padding: 3px 9px;
}
.jw-bs-badge-sale-{{ sid }} { background: #1a1a1a; color: #d4b896; }
.jw-bs-badge-new-{{ sid }}  { background: #b89b6a; color: #fff; }

/* Wish */
.jw-bs-wish-{{ sid }} {
  position: absolute; top: 10px; right: 10px; z-index: 3;
  width: 30px; height: 30px;
  background: rgba(255,255,255,0.88); border: 1px solid #e8e0d5;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all 0.2s; backdrop-filter: blur(3px);
}
.jw-bs-wish-{{ sid }}:hover { background: #1a1a1a; }
.jw-bs-wish-{{ sid }} svg { width: 13px; height: 13px; stroke: #b89b6a; fill: none; stroke-width: 1.5; }

/* Image */
.jw-bs-img-wrap-{{ sid }} { aspect-ratio: 3/4; overflow: hidden; background: #f5f0e8; position: relative; display: block; text-decoration: none; }
.jw-bs-img-{{ sid }}, .jw-bs-img2-{{ sid }} { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: opacity 0.5s, transform 0.6s; }
.jw-bs-img2-{{ sid }} { opacity: 0; }
.jw-bs-card-{{ sid }}:hover .jw-bs-img-{{ sid }} { opacity: 0; transform: scale(1.05); }
.jw-bs-card-{{ sid }}:hover .jw-bs-img2-{{ sid }} { opacity: 1; transform: scale(1.05); }
.jw-bs-noimg-{{ sid }} { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg,#f5f0e8,#ede6d8); font-size: 48px; }
.jw-bs-qv-{{ sid }} { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(26,15,5,0.82); padding: 10px; text-align: center; transform: translateY(100%); transition: transform 0.3s; }
.jw-bs-card-{{ sid }}:hover .jw-bs-qv-{{ sid }} { transform: translateY(0); }
.jw-bs-qv-{{ sid }} span { font-family: 'Jost', sans-serif; font-size: 9.5px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: #d4b896; }

/* Body */
.jw-bs-body-{{ sid }} { padding: 14px 14px 8px; flex: 1; }
.jw-bs-type-{{ sid }} { font-family: 'Jost', sans-serif; font-size: 9px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #b89b6a; margin-bottom: 4px; }
.jw-bs-name-{{ sid }} { font-family: 'Cormorant Garamond', serif; font-size: 15px; font-weight: 400; color: #1a1a1a; line-height: 1.3; margin-bottom: 6px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-decoration: none; letter-spacing: 0.02em; }
.jw-bs-name-{{ sid }}:hover { color: #b89b6a; }
.jw-bs-price-{{ sid }} { display: flex; align-items: baseline; gap: 7px; flex-wrap: wrap; margin-top: 4px; }
.jw-bs-now-{{ sid }} { font-family: 'Cormorant Garamond', serif; font-size: 17px; font-weight: 400; color: #1a1a1a; }
.jw-bs-was-{{ sid }} { font-size: 11.5px; color: #c8bfb2; text-decoration: line-through; }
.jw-bs-off-{{ sid }} { font-size: 9px; font-weight: 600; color: #9b2020; background: #fdf0f0; padding: 2px 5px; letter-spacing: 0.06em; }

/* Variants */
.jw-bs-vars-{{ sid }} { display: flex; flex-wrap: wrap; gap: 4px; margin: 7px 0 2px; }
.jw-bs-vpill-{{ sid }} { padding: 2px 8px; border: 1px solid #e8e0d5; font-family: 'Jost', sans-serif; font-size: 9.5px; font-weight: 500; letter-spacing: 0.05em; color: #4a4a4a; background: transparent; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
.jw-bs-vpill-{{ sid }}:hover:not(.vps) { border-color: #b89b6a; color: #b89b6a; }
.jw-bs-vpill-{{ sid }}.vpa { background: #b89b6a; border-color: #b89b6a; color: #fff; }
.jw-bs-vpill-{{ sid }}.vps { opacity: 0.3; cursor: not-allowed; }

/* Footer */
.jw-bs-foot-{{ sid }} { padding: 0 14px 14px; }
.jw-bs-atc-{{ sid }} { width: 100%; padding: 10px; background: transparent; color: #1a1a1a; border: 1px solid #1a1a1a; font-family: 'Jost', sans-serif; font-size: 9.5px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 7px; transition: all 0.25s; }
.jw-bs-atc-{{ sid }}:hover { background: #1a1a1a; color: #d4b896; }
.jw-bs-atc-{{ sid }}:hover svg { stroke: #b89b6a; }
.jw-bs-atc-{{ sid }}:disabled { opacity: 0.6; cursor: not-allowed; }
.jw-bs-atc-{{ sid }} svg { width: 12px; height: 12px; stroke: #1a1a1a; fill: none; stroke-width: 1.5; }
.jw-bs-sold-{{ sid }} { width: 100%; padding: 10px; background: transparent; color: #c8bfb2; border: 1px solid #e8e0d5; font-family: 'Jost', sans-serif; font-size: 9.5px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; cursor: not-allowed; text-align: center; }

/* Nav arrows */
.jw-bs-nav-{{ sid }} { position: absolute; top: 38%; transform: translateY(-50%); z-index: 5; width: 40px; height: 40px; background: rgba(255,255,255,0.9); border: 1px solid #e8e0d5; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; }
.jw-bs-nav-{{ sid }}:hover { background: #1a1a1a; border-color: #1a1a1a; }
.jw-bs-nav-{{ sid }} svg { width: 16px; height: 16px; stroke: #1a1a1a; fill: none; stroke-width: 2; }
.jw-bs-nav-{{ sid }}:hover svg { stroke: #d4b896; }
.jw-bs-prev-{{ sid }} { left: -12px; }
.jw-bs-next-{{ sid }} { right: -12px; }

@media(max-width:768px) {
  .jw-bs-card-{{ sid }} { flex: 0 0 calc((100% - {{ section.settings.products_per_row_mobile | minus: 1 | times: 20 }}px) / {{ section.settings.products_per_row_mobile }}); }
}
</style>

{% assign coll = collections[section.settings.collection] %}

<section class="jw-bs-{{ sid }}" {{ section.shopify_attributes }}>
  <div class="jw-bs-inner-{{ sid }}">
    <div class="jw-bs-header-{{ sid }}">
      <div class="jw-bs-hgroup-{{ sid }}">
        <div class="jw-bs-eyebrow-{{ sid }}">{{ section.settings.eyebrow | default: 'Featured' }}</div>
        <h2 class="jw-bs-heading-{{ sid }}">{{ section.settings.heading }}</h2>
      </div>
      {% if section.settings.show_view_all and coll %}
        <a class="jw-bs-viewall-{{ sid }}" href="{{ coll.url }}">
          View All
          <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {% endif %}
    </div>

    {% if coll %}
      <div class="jw-bs-outer-{{ sid }}">
        <button class="jw-bs-nav-{{ sid }} jw-bs-prev-{{ sid }}" id="jw-bs-prev-{{ sid }}" aria-label="Previous">
          <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="jw-bs-track-{{ sid }}" id="jw-bs-track-{{ sid }}">
          {% for product in coll.products limit: 12 %}
            {%- assign fv = nil -%}
            {%- for v in product.variants -%}{%- if v.available and fv == nil -%}{%- assign fv = v -%}{%- endif -%}{%- endfor -%}
            {%- if fv == nil -%}{%- assign fv = product.variants.first -%}{%- endif -%}
            {%- assign has_disc = false -%}{%- if product.compare_at_price > product.price -%}{%- assign has_disc = true -%}{%- assign disc_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}{%- endif -%}
            {%- assign now_s = 'now' | date: '%s' | plus: 0 -%}{%- assign cre_s = product.created_at | date: '%s' | plus: 0 -%}{%- assign age_d = now_s | minus: cre_s | divided_by: 86400 -%}
            {%- assign img2 = nil -%}{%- if product.images.size > 1 -%}{%- assign img2 = product.images[1] -%}{%- endif -%}

            <div class="jw-bs-card-{{ sid }}">
              {% if has_disc %}<span class="jw-bs-badge-{{ sid }} jw-bs-badge-sale-{{ sid }}">Sale</span>{% elsif age_d <= 45 %}<span class="jw-bs-badge-{{ sid }} jw-bs-badge-new-{{ sid }}">New</span>{% endif %}
              <button class="jw-bs-wish-{{ sid }}" aria-label="Wishlist"><svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>
              <a href="{{ product.url }}" class="jw-bs-img-wrap-{{ sid }}">
                {% if product.featured_image %}
                  <img class="jw-bs-img-{{ sid }}" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
                  {% if img2 %}<img class="jw-bs-img2-{{ sid }}" src="{{ img2 | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">{% endif %}
                {% else %}
                  <div class="jw-bs-noimg-{{ sid }}">💎</div>
                {% endif %}
                <div class="jw-bs-qv-{{ sid }}"><span>Quick View</span></div>
              </a>
              <div class="jw-bs-body-{{ sid }}">
                <div class="jw-bs-type-{{ sid }}">{{ product.product_type | default: product.tags.first }}</div>
                <a href="{{ product.url }}" class="jw-bs-name-{{ sid }}">{{ product.title }}</a>
                <div class="jw-bs-price-{{ sid }}">
                  <span class="jw-bs-now-{{ sid }}" data-pdisp>{{ fv.price | money }}</span>
                  {% if fv.compare_at_price > fv.price %}<span class="jw-bs-was-{{ sid }}" data-cdisp>{{ fv.compare_at_price | money }}</span><span class="jw-bs-off-{{ sid }}" data-odisp>{{ disc_pct }}% off</span>{% endif %}
                </div>
                {% if product.variants.size > 1 %}
                  <div class="jw-bs-vars-{{ sid }}">
                    {% for v in product.variants %}
                      <button type="button" class="jw-bs-vpill-{{ sid }}{% if v.id == fv.id %} vpa{% endif %}{% unless v.available %} vps{% endunless %}" data-vid="{{ v.id }}" data-price="{{ v.price }}" data-compare="{{ v.compare_at_price | default: 0 }}" data-avail="{{ v.available }}">{{ v.title }}</button>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
              <div class="jw-bs-foot-{{ sid }}">
                {% if product.available %}
                  <button class="jw-bs-atc-{{ sid }}" data-vid="{{ fv.id }}">
                    <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    {{ section.settings.button_text | default: 'Add to Bag' }}
                  </button>
                {% else %}
                  <div class="jw-bs-sold-{{ sid }}">Sold Out</div>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
        <button class="jw-bs-nav-{{ sid }} jw-bs-next-{{ sid }}" id="jw-bs-next-{{ sid }}" aria-label="Next">
          <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    {% endif %}
  </div>
</section>

<script>
(function() {
  var track = document.getElementById('jw-bs-track-{{ sid }}');
  if (!track) return;
  var prev = document.getElementById('jw-bs-prev-{{ sid }}');
  var next = document.getElementById('jw-bs-next-{{ sid }}');
  function scrollBy(dir) {
    var card = track.querySelector('.jw-bs-card-{{ sid }}');
    if (!card) return;
    var w = card.offsetWidth + 20;
    track.scrollBy({ left: dir * w * 2, behavior: 'smooth' });
  }
  if (prev) prev.addEventListener('click', function() { scrollBy(-1); });
  if (next) next.addEventListener('click', function() { scrollBy(1); });

  // Drag scroll
  var isDown = false; var startX; var scrollLeft;
  track.addEventListener('mousedown', function(e) { isDown = true; startX = e.pageX - track.offsetLeft; scrollLeft = track.scrollLeft; });
  track.addEventListener('mouseleave', function() { isDown = false; });
  track.addEventListener('mouseup', function() { isDown = false; });
  track.addEventListener('mousemove', function(e) { if (!isDown) return; e.preventDefault(); var x = e.pageX - track.offsetLeft; track.scrollLeft = scrollLeft - (x - startX); });

  // Variant pills
  track.querySelectorAll('.jw-bs-card-{{ sid }}').forEach(function(card) {
    var pills = card.querySelectorAll('.jw-bs-vpill-{{ sid }}');
    var atc = card.querySelector('.jw-bs-atc-{{ sid }}');
    var pEl = card.querySelector('[data-pdisp]');
    var cEl = card.querySelector('[data-cdisp]');
    var oEl = card.querySelector('[data-odisp]');
    pills.forEach(function(p) {
      p.addEventListener('click', function() {
        if (this.dataset.avail === 'false') return;
        pills.forEach(function(x) { x.classList.remove('vpa'); }); this.classList.add('vpa');
        if (atc) atc.dataset.vid = this.dataset.vid;
        var pr = parseInt(this.dataset.price, 10); var cp = parseInt(this.dataset.compare, 10);
        var fmt = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
        if (pEl) pEl.textContent = fmt.format(pr / 100);
        if (cEl) { if (cp > pr) { cEl.textContent = fmt.format(cp / 100); cEl.style.display = ''; } else { cEl.style.display = 'none'; } }
        if (oEl) { if (cp > pr) { oEl.textContent = Math.round((cp-pr)*100/cp) + '% off'; oEl.style.display = ''; } else { oEl.style.display = 'none'; } }
      });
    });
  });

  // ATC
  function refreshCart(qty, cartData) {
    var total = cartData ? cartData.item_count : qty;
    document.dispatchEvent(new CustomEvent('cart:update', { bubbles: true, detail: { resource: cartData || null, sourceId: 'bs-atc', data: { itemCount: qty, source: 'product-form-component', sections: {} } } }));
    document.querySelectorAll('[ref="cartBubbleCount"],.cart-bubble__count,.cart-count-bubble,[data-cart-count],.cart-count').forEach(function(el) { el.textContent = total > 99 ? '99+' : String(total); el.classList.remove('hidden'); });
    var b = document.querySelector('[ref="cartBubble"],.cart-bubble'); if (b) b.classList.remove('visually-hidden','hidden');
  }
  track.querySelectorAll('.jw-bs-atc-{{ sid }}').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (this.disabled) return;
      var vid = this.dataset.vid; var orig = this.innerHTML; var self = this;
      self.disabled = true; self.innerHTML = '<span>Adding…</span>';
      fetch('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify({ id: parseInt(vid, 10), quantity: 1 }) })
      .then(function(r) { if (!r.ok) return r.json().then(function(e) { throw new Error(e.description || 'Error'); }); return r.json(); })
      .then(function() { self.innerHTML = '<span>✓ Added</span>'; return fetch('/cart.js', { headers: { Accept: 'application/json' } }); })
      .then(function(r) { return r.json(); })
      .then(function(cart) { refreshCart(1, cart); setTimeout(function() { self.innerHTML = orig; self.disabled = false; }, 2200); })
      .catch(function(e) { self.innerHTML = orig; self.disabled = false; alert(e.message || 'Error'); });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Best Selling Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Featured"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Selling Pieces"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#faf8f5"
    },
    {
      "type": "range",
      "id": "products_per_row_desktop",
      "label": "Cards per row (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "label": "Cards per row (mobile)",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All link",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Add to Bag"
    }
  ],
  "presets": [
    {
      "name": "Best Selling Products"
    }
  ]
}
{% endschema %}
