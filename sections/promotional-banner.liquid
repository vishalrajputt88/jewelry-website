{% assign sid = section.id | replace: '_', '' | downcase %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
.jw-promo-{{ sid }} {
  background: {{ section.settings.background_color }};
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
}
.jw-promo-inner-{{ sid }} {
  max-width: 1440px; margin: 0 auto; padding: 0 28px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
}
.jw-promo-card-{{ sid }} {
  position: relative; overflow: hidden;
  aspect-ratio: {{ section.settings.aspect_ratio }};
  display: block; text-decoration: none;
  border: 1px solid #e8e0d5;
}
.jw-promo-card-{{ sid }} img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.6s ease; display: block;
}
.jw-promo-card-{{ sid }}:hover img { transform: scale(1.04); }
.jw-promo-overlay-{{ sid }} {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(20,12,5,0.68) 0%, transparent 55%);
  transition: opacity 0.3s;
}
.jw-promo-card-{{ sid }}:hover .jw-promo-overlay-{{ sid }} { opacity: 0.9; }
.jw-promo-text-{{ sid }} {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 24px 22px;
}
.jw-promo-eyebrow-{{ sid }} {
  font-family: 'Jost', sans-serif; font-size: 9px; font-weight: 600;
  letter-spacing: 0.2em; text-transform: uppercase; color: #b89b6a;
  margin-bottom: 5px;
}
.jw-promo-title-{{ sid }} {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; font-weight: 300; font-style: italic; color: #fff;
  line-height: 1.2; margin-bottom: 8px;
}
.jw-promo-cta-{{ sid }} {
  display: inline-flex; align-items: center; gap: 7px;
  font-family: 'Jost', sans-serif; font-size: 9.5px; font-weight: 600;
  letter-spacing: 0.14em; text-transform: uppercase; color: #d4b896;
  border-bottom: 1px solid rgba(184,155,106,0.5); padding-bottom: 1px;
}
.jw-promo-cta-{{ sid }} svg { width: 11px; height: 11px; stroke: #d4b896; fill: none; stroke-width: 2; transition: transform 0.2s; }
.jw-promo-card-{{ sid }}:hover .jw-promo-cta-{{ sid }} svg { transform: translateX(3px); }
@media(max-width:640px) { .jw-promo-inner-{{ sid }} { grid-template-columns: 1fr; } }
</style>

{% assign cards = '' | split: '' %}
{% assign i = 1 %}
{% for n in (1..4) %}
  {% assign img_key   = 'image_' | append: n %}
  {% assign title_key = 'title_' | append: n %}
  {% assign eyeb_key  = 'eyebrow_' | append: n %}
  {% assign link_key  = 'link_' | append: n %}
  {% assign cta_key   = 'cta_' | append: n %}
  {% if section.settings[img_key] != blank %}
    {% assign cards = cards | push: n %}
  {% endif %}
{% endfor %}

<section class="jw-promo-{{ sid }}" {{ section.shopify_attributes }}>
  <div class="jw-promo-inner-{{ sid }}">
    {% for n in cards %}
      {% assign img_key   = 'image_' | append: n %}
      {% assign title_key = 'title_' | append: n %}
      {% assign eyeb_key  = 'eyebrow_' | append: n %}
      {% assign link_key  = 'link_' | append: n %}
      {% assign cta_key   = 'cta_' | append: n %}
      <a href="{{ section.settings[link_key] | default: '#' }}" class="jw-promo-card-{{ sid }}">
        <img src="{{ section.settings[img_key] | image_url: width: 900 }}" alt="{{ section.settings[title_key] }}" loading="lazy">
        <div class="jw-promo-overlay-{{ sid }}"></div>
        {% if section.settings[title_key] != blank or section.settings[cta_key] != blank %}
          <div class="jw-promo-text-{{ sid }}">
            {% if section.settings[eyeb_key] != blank %}
              <div class="jw-promo-eyebrow-{{ sid }}">{{ section.settings[eyeb_key] }}</div>
            {% endif %}
            {% if section.settings[title_key] != blank %}
              <div class="jw-promo-title-{{ sid }}">{{ section.settings[title_key] }}</div>
            {% endif %}
            {% if section.settings[cta_key] != blank %}
              <span class="jw-promo-cta-{{ sid }}">
                {{ section.settings[cta_key] }}
                <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            {% endif %}
          </div>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</section>

