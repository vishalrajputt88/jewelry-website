      "label": "Mega Panel Tagline",
      "default": "Fine Jewellery"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Grid Columns",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        },
        {
          "value": "6",
          "label": "6"
        }
      ],
      "default": "4"
    },
    {
      "type": "header",
      "content": "Menu Bar Style"
    },
    {
      "type": "color",
      "id": "menu_bg_color",
      "label": "Background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "menu_text_color",
      "label": "Text Color",
      "default": "#d4c4aa"
    },
    {
      "type": "color",
      "id": "menu_hover_color",
