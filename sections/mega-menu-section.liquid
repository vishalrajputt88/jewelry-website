{% comment %}
  Mega Menu Section — Premium Jewelry
  Elegant dark bar with gold accents, full-width collection dropdown
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
/* ─── MEGA MENU WRAPPER ─── */
.jw-mega-wrap {
  background: {{ section.settings.menu_bg_color }};
  position: relative;
  z-index: 200;
  width: 100%;
  border-bottom: 1px solid rgba(184,155,106,0.25);
}
.jw-mega-container {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 28px;
}
.jw-main-menu {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  list-style: none;
  margin: 0; padding: 0;
}
.jw-menu-item { position: static; }
.jw-menu-item > a {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: {{ section.settings.menu_padding }}px 22px;
  color: {{ section.settings.menu_text_color }};
  text-decoration: none;
  font-family: 'Jost', sans-serif;
  font-size: {{ section.settings.menu_font_size }}px;
  font-weight: {{ section.settings.menu_font_weight }};
  letter-spacing: {{ section.settings.menu_letter_spacing }}em;
  text-transform: {{ section.settings.menu_text_transform }};
  transition: color 0.3s;
  white-space: nowrap;
  position: relative;
}
.jw-menu-item > a::after {
  content: '';
  position: absolute;
  bottom: 0; left: 22px; right: 22px; height: 1px;
  background: {{ section.settings.menu_accent_color }};
  transform: scaleX(0);
  transition: transform 0.3s ease;
  transform-origin: center;
}
.jw-menu-item > a:hover { color: {{ section.settings.menu_hover_color }}; }
.jw-menu-item > a:hover::after,
.jw-menu-item.has-mega:hover > a::after { transform: scaleX(1); }

/* Dropdown chevron */
.jw-menu-item.has-mega > a .jw-chevron {
  width: 8px; height: 8px;
  stroke: {{ section.settings.menu_accent_color }};
  fill: none; stroke-width: 2;
  transition: transform 0.3s;
}
.jw-menu-item.has-mega:hover > a .jw-chevron { transform: rotate(180deg); }

/* ─── MEGA DROPDOWN ─── */
.jw-mega-panel {
  display: none;
  position: absolute;
  left: 0; right: 0; width: 100%;
  background: #fff;
  border-top: 2px solid {{ section.settings.menu_accent_color }};
  box-shadow: 0 20px 60px rgba(26,20,10,0.14);
  z-index: 999;
  padding: 0;
}
.jw-menu-item.has-mega:hover .jw-mega-panel { display: block; }

.jw-mega-inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 40px 40px 44px;
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 48px;
}

/* Left column — category label */
.jw-mega-label {
  padding-top: 4px;
  border-right: 1px solid #e8e0d5;
  padding-right: 40px;
}
.jw-mega-cat {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px; font-weight: 300; font-style: italic;
  color: #1a1a1a; line-height: 1.2; margin-bottom: 12px;
}
.jw-mega-tagline {
  font-family: 'Jost', sans-serif;
  font-size: 10.5px; font-weight: 500; letter-spacing: 0.14em;
  text-transform: uppercase; color: #b89b6a;
}
.jw-mega-divider { width: 32px; height: 1px; background: #b89b6a; margin: 14px 0; }
.jw-mega-view-all {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: 'Jost', sans-serif;
  font-size: 10.5px; font-weight: 600; letter-spacing: 0.12em;
  text-transform: uppercase; color: #1a1a1a; text-decoration: none;
  margin-top: 6px; transition: color 0.2s;
}
.jw-mega-view-all:hover { color: #b89b6a; }
.jw-mega-view-all svg { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2; }

/* Collections grid */
.jw-mega-grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
  gap: 18px;
}
.jw-col-card {
  display: block; text-decoration: none;
  border: 1px solid #e8e0d5;
  overflow: hidden; background: #faf8f5;
  transition: border-color 0.3s, box-shadow 0.3s;
  opacity: 0;
  animation: jwFadeUp 0.35s ease forwards;
}
.jw-col-card:hover { border-color: #b89b6a; box-shadow: 0 8px 28px rgba(184,155,106,0.18); }
.jw-col-card:nth-child(1) { animation-delay: 0.04s; }
.jw-col-card:nth-child(2) { animation-delay: 0.08s; }
.jw-col-card:nth-child(3) { animation-delay: 0.12s; }
.jw-col-card:nth-child(4) { animation-delay: 0.16s; }
.jw-col-card:nth-child(5) { animation-delay: 0.20s; }
.jw-col-card:nth-child(6) { animation-delay: 0.24s; }
.jw-col-card:nth-child(7) { animation-delay: 0.28s; }
.jw-col-card:nth-child(8) { animation-delay: 0.32s; }

@keyframes jwFadeUp {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.jw-col-img {
  position: relative; width: 100%; padding-bottom: 75%; overflow: hidden;
  background: #f0ece5;
}
.jw-col-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.45s ease; }
.jw-col-card:hover .jw-col-img img { transform: scale(1.08); }
.jw-col-img-ph { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 32px; background: linear-gradient(135deg,#f5f0e8,#ede6d8); }

.jw-col-info {
  padding: 11px 13px 12px;
  display: flex; align-items: center; justify-content: space-between;
  background: #fff; border-top: 1px solid #e8e0d5;
}
.jw-col-name { font-family: 'Jost', sans-serif; font-size: 11.5px; font-weight: 500; letter-spacing: 0.06em; color: #1a1a1a; text-transform: capitalize; }
.jw-col-arr { font-size: 13px; color: #b89b6a; transition: transform 0.2s; }
.jw-col-card:hover .jw-col-arr { transform: translateX(3px); }

/* ─── MOBILE: hide mega bar ─── */
@media (max-width: 768px) {
  .jw-mega-wrap { display: none !important; }
}

/* ─── MOBILE MEGA (injected into drawer) ─── */
.jw-mob-section { border-top: 1px solid rgba(0,0,0,0.1); margin-top: 4px; }
.jw-mob-item { border-bottom: 1px solid rgba(0,0,0,0.06); }
.jw-mob-toggle {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; padding: 14px 20px;
  background: transparent; border: none;
  font-size: 14px; font-weight: 500; letter-spacing: 0.03em; color: inherit;
  text-align: left; cursor: pointer;
}
.jw-mob-toggle .jw-mob-arr { font-size: 9px; transition: transform 0.25s; color: #b89b6a; }
.jw-mob-item.jw-open .jw-mob-toggle .jw-mob-arr { transform: rotate(180deg); }
.jw-mob-sub { display: none; padding: 4px 12px 14px; background: rgba(0,0,0,0.02); }
.jw-mob-item.jw-open .jw-mob-sub { display: block; }
.jw-mob-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 8px; }
.jw-mob-card {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 10px; border: 1px solid #e8e0d5; background: #fff;
  text-decoration: none; color: #1a1a1a;
  font-size: 11.5px; font-weight: 500; letter-spacing: 0.04em;
  transition: border-color 0.2s;
}
.jw-mob-card:hover { border-color: #b89b6a; }
.jw-mob-card img { width: 30px; height: 30px; object-fit: cover; flex-shrink: 0; }
.jw-mob-ph { width: 30px; height: 30px; background: #f0ece5; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
.jw-mob-plain {
  display: block; padding: 14px 20px;
  font-size: 14px; font-weight: 400; letter-spacing: 0.03em; color: inherit;
  text-decoration: none; border-bottom: 1px solid rgba(0,0,0,0.06);
}
.jw-mob-plain:last-child { border-bottom: none; }
</style>

<div class="jw-mega-wrap">
  <div class="jw-mega-container">
    <nav aria-label="Main navigation">
      <ul class="jw-main-menu" id="jwMainMenu">
        {%- for link in section.settings.main_menu.links -%}
          {%- assign mega_items = section.settings.mega_menu_items | split: ',' -%}
          {%- assign has_mega = false -%}
          {%- for item in mega_items -%}
            {%- assign item_clean = item | strip -%}{%- if item_clean == link.title -%}{%- assign has_mega = true -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
          <li class="jw-menu-item{% if has_mega %} has-mega{% endif %}">
            <a href="{{ link.url }}">
              {{ link.title }}
              {%- if has_mega -%}
                <svg class="jw-chevron" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
              {%- endif -%}
            </a>
            {%- if has_mega -%}
              <div class="jw-mega-panel" role="region">
                <div class="jw-mega-inner">
                  <div class="jw-mega-label">
                    <div class="jw-mega-cat">{{ link.title }}</div>
                    <div class="jw-mega-tagline">{{ section.settings.mega_tagline | default: 'Fine Jewellery' }}</div>
                    <div class="jw-mega-divider"></div>
                    <a class="jw-mega-view-all" href="{{ link.url }}">
                      View All
                      <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                  </div>
                  <div class="jw-mega-grid">
                    {%- for block in section.blocks -%}
                      {%- if block.type == 'collection_cards' and block.settings.parent_menu_item == link.title -%}
                        {%- assign col_ids = 'collection_1,collection_2,collection_3,collection_4,collection_5,collection_6,collection_7,collection_8' | split: ',' -%}
                        {%- for col_id in col_ids -%}
                          {%- assign col_handle = block.settings[col_id] -%}
                          {%- if col_handle != blank -%}
                            {%- assign col = collections[col_handle] -%}
                            <a class="jw-col-card" href="{{ col.url }}" {{ block.shopify_attributes }}>
                              <div class="jw-col-img">
                                {%- if col.image -%}
                                  <img src="{{ col.image | img_url: '400x' }}" alt="{{ col.title }}" loading="lazy">
                                {%- elsif col.products.first.featured_image -%}
                                  <img src="{{ col.products.first.featured_image | img_url: '400x' }}" alt="{{ col.title }}" loading="lazy">
                                {%- else -%}
                                  <div class="jw-col-img-ph">💎</div>
                                {%- endif -%}
                              </div>
                              <div class="jw-col-info">
                                <span class="jw-col-name">{{ col.title }}</span>
                                <span class="jw-col-arr">→</span>
                              </div>
                            </a>
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  </div>
</div>

{%- comment -%} Mobile data JSON {%- endcomment -%}
<script id="jw-mega-mobile-data" type="application/json">
{
  "items": [
    {%- for link in section.settings.main_menu.links -%}
      {%- assign mega_items = section.settings.mega_menu_items | split: ',' -%}
      {%- assign has_mega = false -%}
      {%- for item in mega_items -%}
  {%- assign item_clean = item | strip -%}
  {%- if item_clean == link.title -%}
    {%- assign has_mega = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}
      {%- if forloop.index > 1 -%},{%- endif -%}
      { "title": {{ link.title | json }}, "url": {{ link.url | json }}, "hasMega": {{ has_mega }},
        "collections": [
          {%- if has_mega -%}
            {%- assign cc = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'collection_cards' and block.settings.parent_menu_item == link.title -%}
                {%- assign col_ids = 'collection_1,collection_2,collection_3,collection_4,collection_5,collection_6,collection_7,collection_8' | split: ',' -%}
                {%- for col_id in col_ids -%}
                  {%- assign col_handle = block.settings[col_id] -%}
                  {%- if col_handle != blank -%}
                    {%- assign col = collections[col_handle] -%}
                    {%- if cc > 0 -%},{%- endif -%}
                    { "title": {{ col.title | json }}, "url": {{ col.url | json }}, "image": {%- if col.image -%}{{ col.image | img_url: '80x' | json }}{%- elsif col.products.first.featured_image -%}{{ col.products.first.featured_image | img_url: '80x' | json }}{%- else -%}null{%- endif -%} }
                    {%- assign cc = cc | plus: 1 -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        ]
      }
    {%- endfor -%}
  ]
}
</script>

<script>
(function() {
  function injectMobileMenu() {
    var dataEl = document.getElementById('jw-mega-mobile-data');
    if (!dataEl) return;
    var data;
    try { data = JSON.parse(dataEl.textContent); } catch(e) { return; }
    if (!data || !data.items || !data.items.length) return;

    var drawerNav = document.querySelector('ul.menu-drawer__menu.has-submenu');
    if (!drawerNav) return;
    if (drawerNav.querySelector('.jw-mob-section')) return;

    var wrapLi = document.createElement('li');
    wrapLi.className = 'jw-mob-section';
    wrapLi.style.cssText = 'list-style:none;padding:0;border-top:1px solid rgba(0,0,0,0.1)';

    data.items.forEach(function(item) {
      if (item.hasMega && item.collections && item.collections.length > 0) {
        var itemDiv = document.createElement('div');
        itemDiv.className = 'jw-mob-item';
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'jw-mob-toggle';
        btn.innerHTML = '<span class="menu-drawer__menu-item-text wrap-text">' + item.title + '</span><span class="jw-mob-arr">&#9660;</span>';
        btn.addEventListener('click', function() { itemDiv.classList.toggle('jw-open'); });
        var sub = document.createElement('div');
        sub.className = 'jw-mob-sub';
        var grid = document.createElement('div');
        grid.className = 'jw-mob-grid';
        item.collections.forEach(function(col) {
          var a = document.createElement('a');
          a.href = col.url; a.className = 'jw-mob-card';
          if (col.image) { var img = document.createElement('img'); img.src = col.image; img.alt = col.title; img.loading = 'lazy'; a.appendChild(img); }
          else { var ph = document.createElement('div'); ph.className = 'jw-mob-ph'; ph.textContent = '💎'; a.appendChild(ph); }
          var sp = document.createElement('span'); sp.textContent = col.title; a.appendChild(sp);
          grid.appendChild(a);
        });
        sub.appendChild(grid); itemDiv.appendChild(btn); itemDiv.appendChild(sub);
        wrapLi.appendChild(itemDiv);
      } else {
        var a = document.createElement('a');
        a.href = item.url;
        a.className = 'jw-mob-plain menu-drawer__menu-item menu-drawer__animated-element focus-inset';
        a.innerHTML = '<span class="menu-drawer__menu-item-text wrap-text">' + item.title + '</span>';
        wrapLi.appendChild(a);
      }
    });
    drawerNav.appendChild(wrapLi);
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', injectMobileMenu);
  else injectMobileMenu();
  setTimeout(injectMobileMenu, 500);
  setTimeout(injectMobileMenu, 1500);

  document.addEventListener('click', function(e) {
    if (e.target.closest('summary.header__icon--summary,.header__icon--menu')) setTimeout(injectMobileMenu, 150);
  });

  var obs = new MutationObserver(function() {
    var nav = document.querySelector('ul.menu-drawer__menu.has-submenu');
    if (nav && !nav.querySelector('.jw-mob-section')) injectMobileMenu();
  });
  obs.observe(document.body, { childList: true, subtree: true });
})();
</script>

{% schema %}
{
  "name": "Jewelry Mega Menu",
  "settings": [
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main Menu",
      "default": "main-menu"
    },
    {
