{% assign sid = section.id | replace: '_', '' | downcase %}
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
.jw-benefits-{{ sid }} {
  background: {{ section.settings.section_background_color }};
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  border-top: 1px solid #e8e0d5;
  border-bottom: 1px solid #e8e0d5;
}
.jw-benefits-inner-{{ sid }} {
  max-width: 1440px; margin: 0 auto; padding: 0 28px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}
.jw-benefit-item-{{ sid }} {
  display: flex; align-items: center; gap: 14px;
  padding: 18px 24px;
  border-right: 1px solid #e8e0d5;
}
.jw-benefit-item-{{ sid }}:last-child { border-right: none; }
.jw-benefit-icon-{{ sid }} {
  width: 42px; height: 42px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  background: {{ section.settings.icon_background_color }};
}
.jw-benefit-icon-{{ sid }} img { width: 22px; height: 22px; object-fit: contain; filter: brightness(0) invert(1); }
.jw-benefit-icon-{{ sid }} svg { width: 20px; height: 20px; stroke: #ffffff; fill: none; stroke-width: 1.5; }
.jw-benefit-text-{{ sid }} {}
.jw-benefit-title-{{ sid }} {
  font-family: 'Jost', sans-serif;
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: {{ section.settings.text_color }};
  line-height: 1.3; margin-bottom: 2px;
}
.jw-benefit-sub-{{ sid }} {
  font-family: 'Jost', sans-serif;
  font-size: 11px; font-weight: 300;
  color: #6a6258; letter-spacing: 0.03em;
}
@media(max-width:768px) {
  .jw-benefits-inner-{{ sid }} { grid-template-columns: repeat(2,1fr); }
  .jw-benefit-item-{{ sid }}:nth-child(2) { border-right: none; }
  .jw-benefit-item-{{ sid }}:nth-child(2),
  .jw-benefit-item-{{ sid }}:nth-child(4) { border-right: none; }
  .jw-benefit-item-{{ sid }}:nth-child(3),
  .jw-benefit-item-{{ sid }}:nth-child(4) { border-top: 1px solid #e8e0d5; }
}
@media(max-width:480px) {
  .jw-benefits-inner-{{ sid }} { grid-template-columns: 1fr; }
  .jw-benefit-item-{{ sid }} { border-right: none !important; border-top: 1px solid #e8e0d5; }
  .jw-benefit-item-{{ sid }}:first-child { border-top: none; }
}
</style>

{% capture default_icons %}
<svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
<svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
<svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
{% endcapture %}
{% assign icons = default_icons | split: '</svg>' %}

<section class="jw-benefits-{{ sid }}" {{ section.shopify_attributes }}>
  <div class="jw-benefits-inner-{{ sid }}">
    {% assign features = 'feature_1,feature_2,feature_3,feature_4' | split: ',' %}
    {% for feat in features %}
      {% assign title_key = feat | append: '_title' %}
      {% assign icon_key  = feat | append: '_icon' %}
      {% assign sub_key   = feat | append: '_subtitle' %}
      {% if section.settings[title_key] != blank %}
        <div class="jw-benefit-item-{{ sid }}">
          <div class="jw-benefit-icon-{{ sid }}" style="background:{{ section.settings.icon_background_color }}">
            {% if section.settings[icon_key] != blank %}
              <img src="{{ section.settings[icon_key] | image_url: width: 80 }}" alt="{{ section.settings[title_key] }}">
            {% else %}
              {% case forloop.index %}
                {% when 1 %}<svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {% when 2 %}<svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {% when 3 %}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {% when 4 %}<svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {% endcase %}
            {% endif %}
          </div>
          <div class="jw-benefit-text-{{ sid }}">
            <div class="jw-benefit-title-{{ sid }}">{{ section.settings[title_key] }}</div>
            {% if section.settings[sub_key] != blank %}
              <div class="jw-benefit-sub-{{ sid }}">{{ section.settings[sub_key] }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

