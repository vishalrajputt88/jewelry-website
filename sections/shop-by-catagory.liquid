{% assign sid = section.id | replace: '_', '' | downcase %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
.jw-cats-{{ sid }} {
  background: {{ section.settings.background_color }};
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
}
.jw-cats-inner-{{ sid }} {
  max-width: 1440px; margin: 0 auto; padding: 0 28px;
}
.jw-cats-header-{{ sid }} {
  text-align: center; margin-bottom: 48px;
}
.jw-cats-eyebrow-{{ sid }} {
  font-family: 'Jost', sans-serif;
  font-size: 10px; font-weight: 600; letter-spacing: 0.22em;
  text-transform: uppercase; color: #b89b6a;
  margin-bottom: 10px;
  display: flex; align-items: center; justify-content: center; gap: 14px;
}
.jw-cats-eyebrow-{{ sid }}::before,
.jw-cats-eyebrow-{{ sid }}::after { content: ''; display: block; width: 36px; height: 1px; background: #b89b6a; }
.jw-cats-title-{{ sid }} {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(32px, 3.5vw, 48px);
  font-weight: 300; font-style: italic;
  color: {{ section.settings.heading_color }};
  line-height: 1.1;
}
.jw-cats-grid-{{ sid }} {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  gap: {{ section.settings.item_gap }}px;
}
.jw-cat-item-{{ sid }} {
  display: block; text-decoration: none;
  position: relative; overflow: hidden;
  background: #f0ece5;
  border: 1px solid #e8e0d5;
  transition: box-shadow 0.35s, border-color 0.35s;
  aspect-ratio: 1/1;
}
.jw-cat-item-{{ sid }}:hover { box-shadow: 0 12px 40px rgba(26,20,10,0.14); border-color: #b89b6a; }
.jw-cat-img-{{ sid }} {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
  display: block;
}
.jw-cat-item-{{ sid }}:hover .jw-cat-img-{{ sid }} { transform: scale(1.06); }
.jw-cat-overlay-{{ sid }} {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(20,12,5,0.75) 0%, transparent 55%);
  transition: opacity 0.3s;
}
.jw-cat-item-{{ sid }}:hover .jw-cat-overlay-{{ sid }} { opacity: 0.9; }
.jw-cat-info-{{ sid }} {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 18px 16px;
  display: flex; align-items: flex-end; justify-content: space-between;
}
.jw-cat-name-{{ sid }} {
  font-family: 'Jost', sans-serif;
  font-size: 13px; font-weight: 500;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: #ffffff; line-height: 1.3;
}
.jw-cat-arr-{{ sid }} {
  width: 30px; height: 30px;
  border: 1px solid rgba(184,155,106,0.6);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: background 0.2s, border-color 0.2s;
}
.jw-cat-item-{{ sid }}:hover .jw-cat-arr-{{ sid }} { background: #b89b6a; border-color: #b89b6a; }
.jw-cat-arr-{{ sid }} svg { width: 13px; height: 13px; stroke: #b89b6a; fill: none; stroke-width: 2; }
.jw-cat-item-{{ sid }}:hover .jw-cat-arr-{{ sid }} svg { stroke: #fff; }
/* No image fallback */
.jw-cat-noimg-{{ sid }} {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #f5f0e8, #ede6d8);
  font-size: 42px;
}
@media(max-width:1024px) { .jw-cats-grid-{{ sid }} { grid-template-columns: repeat(4,1fr) !important; } }
@media(max-width:768px)  { .jw-cats-grid-{{ sid }} { grid-template-columns: repeat(3,1fr) !important; gap: 12px; } }
@media(max-width:480px)  { .jw-cats-grid-{{ sid }} { grid-template-columns: repeat(2,1fr) !important; gap: 10px; } }
</style>

<section class="jw-cats-{{ sid }}" {{ section.shopify_attributes }}>
  <div class="jw-cats-inner-{{ sid }}">
    <div class="jw-cats-header-{{ sid }}">
      {% if section.settings.eyebrow != blank %}
        <div class="jw-cats-eyebrow-{{ sid }}">{{ section.settings.eyebrow }}</div>
      {% endif %}
      <h2 class="jw-cats-title-{{ sid }}">{{ section.settings.heading }}</h2>
    </div>
    <div class="jw-cats-grid-{{ sid }}">
      {% for block in section.blocks %}
        {% if block.type == 'category_item' %}
          <a href="{{ block.settings.category_url }}" class="jw-cat-item-{{ sid }}" {{ block.shopify_attributes }}>
            {% if block.settings.category_image != blank %}
              <img class="jw-cat-img-{{ sid }}" src="{{ block.settings.category_image | image_url: width: 600 }}" alt="{{ block.settings.category_title }}" loading="lazy">
            {% else %}
              <div class="jw-cat-noimg-{{ sid }}">💎</div>
            {% endif %}
            <div class="jw-cat-overlay-{{ sid }}"></div>
            <div class="jw-cat-info-{{ sid }}">
              <span class="jw-cat-name-{{ sid }}">{{ block.settings.category_title }}</span>
              <div class="jw-cat-arr-{{ sid }}">
                <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </div>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Category",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop by Category"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#faf8f5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 20,
      "max": 100,
      "step": 4,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 20,
      "max": 100,
      "step": 4,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop Columns",
      "options": [
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        },
        {
          "value": "6",
          "label": "6"
        },
        {
          "value": "7",
          "label": "7"
        },
        {
          "value": "8",
          "label": "8"
        }
      ],
      "default": "5"
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Gap",
      "min": 8,
      "max": 28,
      "step": 2,
      "default": 16,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "category_item",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "category_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "category_title",
          "label": "Title",
          "default": "Rings"
        },
        {
          "type": "url",
          "id": "category_url",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Shop by Category",
      "blocks": [
        {
          "type": "category_item",
          "settings": {
            "category_title": "Rings"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "category_title": "Necklaces"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "category_title": "Earrings"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "category_title": "Bangles"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "category_title": "Bracelets"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "category_title": "Pendants"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "category_title": "Anklets"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "category_title": "Chains"
          }
        }
      ]
    }
  ]
}
{% endschema %}
