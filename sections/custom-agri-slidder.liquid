{% assign sid = section.id | replace: '_', '' | downcase %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
.jw-slider-{{ sid }} {
  position: relative;
  width: 100%; overflow: hidden;
  background: #1a1a1a;
}
.jw-slider-track-{{ sid }} {
  display: flex;
  transition: transform 0.7s cubic-bezier(0.77,0,0.175,1);
  will-change: transform;
}
.jw-slide-{{ sid }} {
  position: relative;
  flex: 0 0 100%;
  width: 100%;
  aspect-ratio: 16/7;
  overflow: hidden;
  background: #111;
}
@media(max-width:749px) { .jw-slide-{{ sid }} { aspect-ratio: 3/4; } }
.jw-slide-img-{{ sid }} {
  position: absolute; inset: 0; width: 100%; height: 100%;
  object-fit: cover; object-position: center;
  transition: transform 8s ease;
}
.jw-slide-{{ sid }}.is-active .jw-slide-img-{{ sid }} { transform: scale(1.04); }
.jw-slide-overlay-{{ sid }} {
  position: absolute; inset: 0;
  background: linear-gradient(105deg, rgba(20,12,5,0.72) 0%, rgba(20,12,5,0.28) 55%, transparent 100%);
}
.jw-slide-content-{{ sid }} {
  position: absolute; top: 50%; left: 6%; transform: translateY(-50%);
  max-width: 600px; z-index: 2;
  opacity: 0; transform: translateY(calc(-50% + 20px));
  transition: opacity 0.6s 0.25s, transform 0.6s 0.25s;
}
.jw-slide-{{ sid }}.is-active .jw-slide-content-{{ sid }} {
  opacity: 1; transform: translateY(-50%);
}
.jw-slide-eyebrow-{{ sid }} {
  display: flex; align-items: center; gap: 12px;
  font-family: 'Jost', sans-serif;
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: #b89b6a; margin-bottom: 14px;
}
.jw-slide-eyebrow-{{ sid }}::before {
  content: ''; display: block; width: 36px; height: 1px; background: #b89b6a;
}
.jw-slide-heading-{{ sid }} {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(36px, 5vw, 72px);
  font-weight: 300; font-style: italic;
  color: #ffffff; line-height: 1.08;
  margin-bottom: 16px; letter-spacing: 0.02em;
}
.jw-slide-subtext-{{ sid }} {
  font-family: 'Jost', sans-serif;
  font-size: clamp(13px, 1.4vw, 16px);
  font-weight: 300; color: #e0d0bc;
  letter-spacing: 0.04em; margin-bottom: 28px;
  max-width: 440px; line-height: 1.7;
}
.jw-slide-cta-{{ sid }} {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 13px 28px;
  background: transparent;
  border: 1px solid #b89b6a;
  color: #d4b896;
  font-family: 'Jost', sans-serif;
  font-size: 10.5px; font-weight: 600;
  letter-spacing: 0.18em; text-transform: uppercase;
  text-decoration: none;
  transition: background 0.3s, color 0.3s;
}
.jw-slide-cta-{{ sid }}:hover { background: #b89b6a; color: #fff; }
.jw-slide-cta2-{{ sid }} {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 13px 28px;
  background: #b89b6a; color: #fff;
  font-family: 'Jost', sans-serif;
  font-size: 10.5px; font-weight: 600;
  letter-spacing: 0.18em; text-transform: uppercase;
  text-decoration: none; margin-left: 12px;
  transition: background 0.3s;
}
.jw-slide-cta2-{{ sid }}:hover { background: #8a7050; }
.jw-slide-btns-{{ sid }} { display: flex; flex-wrap: wrap; gap: 10px; }

/* Nav arrows */
.jw-nav-{{ sid }} {
  position: absolute; top: 50%; transform: translateY(-50%);
  z-index: 10; width: 46px; height: 46px;
  background: rgba(26,15,5,0.55); border: 1px solid rgba(184,155,106,0.5);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: background 0.2s, border-color 0.2s;
  backdrop-filter: blur(4px);
}
.jw-nav-{{ sid }}:hover { background: rgba(184,155,106,0.8); border-color: #b89b6a; }
.jw-nav-{{ sid }} svg { width: 18px; height: 18px; stroke: #d4b896; fill: none; stroke-width: 1.5; }
.jw-nav-{{ sid }}:hover svg { stroke: #fff; }
.jw-nav-prev-{{ sid }} { left: 20px; }
.jw-nav-next-{{ sid }} { right: 20px; }

/* Dots */
.jw-dots-{{ sid }} {
  position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
  display: flex; gap: 8px; z-index: 10;
}
.jw-dot-{{ sid }} {
  width: 6px; height: 6px; border-radius: 50%;
  background: rgba(255,255,255,0.35); cursor: pointer;
  transition: all 0.3s; border: 1px solid rgba(255,255,255,0.3);
}
.jw-dot-{{ sid }}.active { background: #b89b6a; border-color: #b89b6a; width: 20px; border-radius: 3px; }

/* Slide counter */
.jw-counter-{{ sid }} {
  position: absolute; bottom: 20px; right: 24px; z-index: 10;
  font-family: 'Jost', sans-serif; font-size: 10px;
  letter-spacing: 0.1em; color: rgba(255,255,255,0.5);
}
.jw-counter-{{ sid }} span { color: #b89b6a; font-weight: 600; }

@media(max-width:749px) {
  .jw-slide-content-{{ sid }} { left: 5%; max-width: 90%; }
  .jw-nav-{{ sid }} { display: none; }
}
</style>

{%- assign slides = '' | split: '' -%}
{%- for i in (1..5) -%}
  {%- assign img_key = 'slide_' | append: i | append: '_image' -%}
  {%- assign mob_key = 'slide_' | append: i | append: '_mobile_image' -%}
  {%- assign h_key = 'slide_' | append: i | append: '_heading' -%}
  {%- assign sub_key = 'slide_' | append: i | append: '_subheading' -%}
  {%- assign btn_key = 'slide_' | append: i | append: '_button_text' -%}
  {%- assign lnk_key = 'slide_' | append: i | append: '_button_link' -%}
  {%- assign b2_key = 'slide_' | append: i | append: '_button2_text' -%}
  {%- assign l2_key = 'slide_' | append: i | append: '_button2_link' -%}
  {%- assign eyebrow_key = 'slide_' | append: i | append: '_eyebrow' -%}
  {%- if section.settings[img_key] != blank -%}
    {%- assign slides = slides | push: i -%}
  {%- endif -%}
{%- endfor -%}

<div class="jw-slider-{{ sid }}" id="jw-slider-{{ sid }}" {{ section.shopify_attributes }}>
  <div class="jw-slider-track-{{ sid }}" id="jw-track-{{ sid }}">
    {%- for i in slides -%}
      {%- assign img_key = 'slide_' | append: i | append: '_image' -%}
      {%- assign mob_key = 'slide_' | append: i | append: '_mobile_image' -%}
      {%- assign h_key = 'slide_' | append: i | append: '_heading' -%}
      {%- assign sub_key = 'slide_' | append: i | append: '_subheading' -%}
      {%- assign btn_key = 'slide_' | append: i | append: '_button_text' -%}
      {%- assign lnk_key = 'slide_' | append: i | append: '_button_link' -%}
      {%- assign b2_key = 'slide_' | append: i | append: '_button2_text' -%}
      {%- assign l2_key = 'slide_' | append: i | append: '_button2_link' -%}
      {%- assign eyebrow_key = 'slide_' | append: i | append: '_eyebrow' -%}
      <div class="jw-slide-{{ sid }}{% if forloop.first %} is-active{% endif %}">
        <picture>
          {% if section.settings[mob_key] != blank %}
            <source media="(max-width:749px)" srcset="{{ section.settings[mob_key] | image_url: width: 800 }}">
          {% endif %}
          <img class="jw-slide-img-{{ sid }}" src="{{ section.settings[img_key] | image_url: width: 1800 }}" alt="{{ section.settings[h_key] | default: 'Jewelry' }}" loading="{{ forloop.first | iif: 'eager', 'lazy' }}">
        </picture>
        <div class="jw-slide-overlay-{{ sid }}"></div>
        <div class="jw-slide-content-{{ sid }}">
          {%- if section.settings[eyebrow_key] != blank -%}
            <div class="jw-slide-eyebrow-{{ sid }}">{{ section.settings[eyebrow_key] }}</div>
          {%- endif -%}
          {%- if section.settings[h_key] != blank -%}
            <h2 class="jw-slide-heading-{{ sid }}">{{ section.settings[h_key] }}</h2>
          {%- endif -%}
          {%- if section.settings[sub_key] != blank -%}
            <p class="jw-slide-subtext-{{ sid }}">{{ section.settings[sub_key] }}</p>
          {%- endif -%}
          <div class="jw-slide-btns-{{ sid }}">
            {%- if section.settings[btn_key] != blank -%}
              <a href="{{ section.settings[lnk_key] | default: '#' }}" class="jw-slide-cta-{{ sid }}">
                {{ section.settings[btn_key] }}
              </a>
            {%- endif -%}
            {%- if section.settings[b2_key] != blank -%}
              <a href="{{ section.settings[l2_key] | default: '#' }}" class="jw-slide-cta2-{{ sid }}">
                {{ section.settings[b2_key] }}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {% if slides.size > 1 %}
    <button class="jw-nav-{{ sid }} jw-nav-prev-{{ sid }}" id="jw-prev-{{ sid }}" aria-label="Previous">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="jw-nav-{{ sid }} jw-nav-next-{{ sid }}" id="jw-next-{{ sid }}" aria-label="Next">
      <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div class="jw-dots-{{ sid }}" id="jw-dots-{{ sid }}">
      {%- for i in slides -%}
        <button class="jw-dot-{{ sid }}{% if forloop.first %} active{% endif %}" data-idx="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>
    <div class="jw-counter-{{ sid }}" id="jw-ctr-{{ sid }}"><span>01</span> / {{ slides.size | prepend: '0' }}</div>
  {% endif %}
</div>

<script>
(function() {
  var slider = document.getElementById('jw-slider-{{ sid }}');
  var track  = document.getElementById('jw-track-{{ sid }}');
  if (!slider || !track) return;
  var slides = track.querySelectorAll('.jw-slide-{{ sid }}');
  var dots   = slider.querySelectorAll('.jw-dot-{{ sid }}');
  var ctr    = document.getElementById('jw-ctr-{{ sid }}');
  var cur = 0; var total = slides.length; var timer;

  function go(n) {
    slides[cur].classList.remove('is-active');
    dots[cur] && dots[cur].classList.remove('active');
    cur = (n + total) % total;
    slides[cur].classList.add('is-active');
    dots[cur] && dots[cur].classList.add('active');
    track.style.transform = 'translateX(-' + (cur * 100) + '%)';
    if (ctr) ctr.querySelector('span').textContent = String(cur + 1).padStart(2,'0');
  }
  function start() { timer = setInterval(function() { go(cur + 1); }, {{ section.settings.autoplay_speed | default: 5 }} * 1000); }
  function stop() { clearInterval(timer); }

  var prev = document.getElementById('jw-prev-{{ sid }}');
  var next = document.getElementById('jw-next-{{ sid }}');
  if (prev) prev.addEventListener('click', function() { stop(); go(cur - 1); start(); });
  if (next) next.addEventListener('click', function() { stop(); go(cur + 1); start(); });
  dots.forEach(function(d) {
    d.addEventListener('click', function() { stop(); go(parseInt(this.dataset.idx)); start(); });
  });
  slider.addEventListener('mouseenter', stop);
  slider.addEventListener('mouseleave', start);

  // Touch swipe
  var tx = 0;
  slider.addEventListener('touchstart', function(e) { tx = e.touches[0].clientX; }, { passive: true });
  slider.addEventListener('touchend', function(e) {
    var diff = tx - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) { stop(); go(diff > 0 ? cur + 1 : cur - 1); start(); }
  }, { passive: true });

  if (total > 1) start();
})();
</script>

