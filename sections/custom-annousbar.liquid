{% assign sid = section.id | replace: '_', '' | downcase %}
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
.jw-annbar-{{ sid }} {
  background: {{ section.settings.background_color }};
  width: 100%; overflow: hidden;
}
.jw-annbar-inner-{{ sid }} {
  display: flex; align-items: center; justify-content: center;
  max-width: 100%; overflow: hidden;
  position: relative;
}
.jw-annbar-track-{{ sid }} {
  display: flex; align-items: center;
  white-space: nowrap;
  animation: jwAnnScroll{{ sid }} 28s linear infinite;
}
.jw-annbar-track-{{ sid }}:hover { animation-play-state: paused; }
@keyframes jwAnnScroll{{ sid }} {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.jw-ann-item-{{ sid }} {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 9px 36px;
  font-family: 'Jost', sans-serif;
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: {{ section.settings.text_color }};
  white-space: nowrap;
}
.jw-ann-dot-{{ sid }} {
  width: 4px; height: 4px; border-radius: 50%;
  background: {{ section.settings.accent_color }};
  flex-shrink: 0;
}
</style>

<div class="jw-annbar-{{ sid }}" {{ section.shopify_attributes }}>
  <div class="jw-annbar-inner-{{ sid }}">
    <div class="jw-annbar-track-{{ sid }}">
      {%- assign msgs = section.settings.messages | split: '|' -%}
      {%- for i in (1..2) -%}
        {%- for msg in msgs -%}
          <span class="jw-ann-item-{{ sid }}">
            <span class="jw-ann-dot-{{ sid }}"></span>
            {{ msg | strip }}
            <span class="jw-ann-dot-{{ sid }}"></span>
          </span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "textarea",
      "id": "messages",
      "label": "Messages (separate with |)",
      "default": "Free Shipping on Orders Above ₹2,999 | BIS Hallmarked Gold Jewellery | IGI Certified Diamonds | 30-Day Easy Returns | EMI Available | Lifetime Polishing Free"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#d4b896"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Dot Accent",
      "default": "#b89b6a"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
